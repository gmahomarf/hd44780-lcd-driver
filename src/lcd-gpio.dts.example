/dts-v1/;
/plugin/;

/*
   On my setup (kernel 6.19.13-bone16), gpioN does NOT map to gpiochipN
   Instead it maps as the following:
     - gpio0 => gpiochip3
     - gpio1 => gpiochip0
     - gpio2 => gpiochip1
     - gpio3 => gpiochip2

   Keep that in mind when changing the assigned pins for each function.
   Format is as follows:
        <&gpiochip line_offset state>
   where:
        - `gpiochip` is one of the four values above.
        - `line_offset` is the offset of the pin on the chip (line N in `gpioinfo` output)
        - `active_state` is the active state of the line, i.e., whether setting it to active means a high output or
          a low output (0: high, 1: low)

   Run `gpioinfo` on your BeagleBone Black terminal for more details
*/

&{/} {
	hd44780_lcd {
		ops-gpios = <&gpio0 26 0>, // RS => P8_14
		            <&gpio1 15 0>, // RW => P8_15
		            <&gpio1 14 0>, // Enable => P8_16
		// Data pins
		            <&gpio2 2 0>, // D4 => P8_7
		            <&gpio2 3 0>, // D5 => P8_8
		            <&gpio2 5 0>, // D6 => P8_9
		            <&gpio2 4 0>; // D7 => P8_10

		/** Uncomment this block to enable RGB lighting
		pwm-names = "backlight_r", "backlight_g", "backlight_b";

		// The RGB LEDs have a common anode, so enabling each one involves grounding its respective pin.
		// Setting them to active low reduces cognitive overhead because setting its value
		// to 1 turns it on and setting it to 0 turns it off
		// DO NOT CHANGE THESE VALUES UNLESS YOU'VE LOADED A DIFFERENT OVERLAY!!!!
		pwms = <&ehrpwm0 1 50000 1>, // R => P9_29
		       <&ehrpwm0 0 50000 1>, // G => P9_31
		       <&ehrpwm1 0 50000 1>; // B => P9_14
		*/
	};
};